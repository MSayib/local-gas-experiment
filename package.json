{
  "name": "gas-experiment-dashboard",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently \"bun run dev:client\" \"bun run dev:server\"",
    "dev:client": "vite --config vite.config.ts",
    "dev:server": "bun --watch src/server/local/index.ts",
    "build": "bun run build:server && bun run build:client",
    "build:server": "node esbuild.config.cjs",
    "build:client": "vite build --config vite.config.ts",
    "test": "jest",
    "type-check": "tsc --noEmit",
    "deploy": "bun run build && npx clasp push --force",
    "db:migrate": "dbmate --migrations-dir db/migrations up",
    "db:rollback": "dbmate --migrations-dir db/migrations down",
    "db:status": "dbmate --migrations-dir db/migrations status",
    "db:seed": "bun src/db/seed.ts"
  },
  "devDependencies": {
    "@google/clasp": "^3.3.0",
    "@types/bun": "latest",
    "@types/google-apps-script": "^2.0.8",
    "@types/jest": "^30.0.0",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^9.2.1",
    "dotenv": "^17.4.2",
    "esbuild": "^0.28.0",
    "jest": "^30.3.0",
    "pg": "^8.20.0",
    "ts-jest": "^29.4.9",
    "vite": "^8.0.10",
    "vite-plugin-singlefile": "^2.3.3"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "hono": "^4.12.16",
    "react": "^19.2.5",
    "react-dom": "^19.2.5"
  }
}
